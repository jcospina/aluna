# Dependencies (created by `bun install`)
node_modules/

# Build output
dist/
artifacts/

# Runtime-generated artifacts — keep the directory structure (READMEs) tracked,
# ignore everything written at runtime. (ARCH §5, §6.3; Epic 1.1)

# Generated capability snapshots: capabilities/<id>/<incarnation_id>/v<n>/
# (authored spec history + .ts handlers/item renderer + optional frozen tests)
capabilities/*
!capabilities/README.md

# Object-store blobs: storage/<key>
storage/*
!storage/README.md

# SQLite database file + its WAL/SHM/journal sidecars
data/*
!data/README.md

# Env vars
.env
