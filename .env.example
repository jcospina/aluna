# Aluna — environment configuration.
# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
# The AI provider spine swaps providers by one trio of env vars (ADR-0003):
# the key, the model, and the endpoint. Only the key is required; the model and
# endpoint have defaults and only need setting to move off OpenAI / gpt-5.6-terra.

# REQUIRED — your provider API key (bring-your-own-key). Provider-neutral: the
# value may be an OpenAI, Anthropic, or any compatible provider's key. The app
# throws (naming this variable) when it needs the provider and this is unset.
OMNI_API_KEY=

# OPTIONAL — override the single global model. Default: gpt-5.6-terra.
# OMNI_MODEL=gpt-5.6-terra

# OPTIONAL — override the provider endpoint. The spine reads the wire shape
# (OpenAI-compatible vs Anthropic Messages) off this URL. Swapping model usually
# means swapping the endpoint too — change both together (e.g. a claude-* id
# with the Anthropic endpoint). Default: https://api.openai.com/v1
# OMNI_BASE_URL=https://api.openai.com/v1
