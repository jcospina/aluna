{
  "compilerOptions": {
    // Environment & target — ESNext, run by Bun (ARCH §4)
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",

    // Bun resolves modules like a bundler and runs .ts directly
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Strictness
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  // Hand-written/generated capability handlers (ADR-0004) carry no imports and no
  // type annotations on purpose — the platform's tsc never checks them; the gate
  // (epic 2.5) type-checks generated handlers in isolation. The 2.3 tracer-bullet
  // fixtures mirror that, so they are excluded here too.
  "exclude": ["src/router/__fixtures__"]
}
