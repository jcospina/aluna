{
  "name": "omni-crud",
  "version": "0.1.0",
  "private": true,
  "description": "Omni-CRUD platform — Bun runtime spine",
  "type": "module",
  "module": "src/index.ts",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun ./dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
