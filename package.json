{
  "name": "omni-crud",
  "version": "0.1.0",
  "private": true,
  "description": "Omni-CRUD platform — Bun runtime spine",
  "type": "module",
  "module": "src/index.ts",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun ./dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.browser.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,json,jsonc,css}": [
      "bunx biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "hono": "^4.12.23"
  }
}
